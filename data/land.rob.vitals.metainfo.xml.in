<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>land.rob.vitals</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Vitals</name>
  <summary>Track health from watches, sensors and manual logs</summary>

  <description>
    <p>
      Vitals is a local-first health tracker: it syncs smartwatches
      (Pebble, Bangle.js, PineTime) and standard Bluetooth health
      sensors (blood-pressure cuffs, scales, glucose meters, pulse
      oximeters, thermometers), and logs food, water and measurements
      by hand. Everything lands in one on-device database. No account,
      no cloud — optionally replicate to your own Vault server.
    </p>
    <ul>
      <li>Dashboard: steps, calories eaten vs burned, water, weight,
      heart rate and sleep at a glance</li>
      <li>Timeline: everything you logged, day by day</li>
      <li>Devices: pair watches and sensors, sync, install watch apps
      and firmware, manage alarms and weather</li>
      <li>Food lookup via Open Food Facts and USDA FoodData Central</li>
      <li>Adaptive layout for desktop GNOME and Phosh phones</li>
    </ul>
  </description>

  <launchable type="desktop-id">land.rob.vitals.desktop</launchable>

  <url type="homepage">https://codeberg.org/robland/vitals</url>
  <url type="bugtracker">https://codeberg.org/robland/vitals/issues</url>

  <developer id="land.rob">
    <name>Rob Daniel</name>
  </developer>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="0.9.0" date="2026-07-05">
      <description>
        <p>The unification: tock, pulse, larder, jot and gauge merge
        into one app. Adopts the existing Pulse database on first run;
        watch hardware flows await on-device verification.</p>
      </description>
    </release>
    <release version="0.1.0" date="2026-06-03">
      <description>
        <p>First release: Today, Trends and Permissions views over Pulse.</p>
      </description>
    </release>
  </releases>
</component>
